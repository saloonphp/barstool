{
    "name": "saloonphp/barstool",
    "description": "A Laravel package for logging Saloon Requests & Response.",
    "keywords": [
        "laravel",
        "barstool",
        "saloon",
        "saloonphp",
        "logging",
        "http"
    ],
    "homepage": "https://github.com/saloonphp/barstool",
    "license": "MIT",
    "authors": [
        {
            "name": "Craig Potter",
            "email": "1442635+craigpotter@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "illuminate/contracts": "^12.0 | ^13.0",
        "saloonphp/saloon": "^4.0",
        "spatie/laravel-package-tools": "^1.16.4"
    },
    "require-dev": {
        "larastan/larastan": "^3.1.0",
        "laravel/pint": "^1.20.0",
        "nunomaduro/collision": "^8.6.1",
        "orchestra/testbench": "^10.0 | ^11.0",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.39.0"
    },
    "autoload": {
        "psr-4": {
            "Saloon\\Barstool\\": "src/",
            "Saloon\\Barstool\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Saloon\\Barstool\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-barstool --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Saloon\\Barstool\\BarstoolServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
